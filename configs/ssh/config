# ================= 量化系统专用 SSH 配置 =================
# 用途：隔离个人/公司/客户仓库，防密钥混淆与权限泄露
# 位置：~/.ssh/config 或项目级 .ssh/config (需 git config core.sshCommand)

# --- 公司主仓库 (高权限) ---
Host github-company
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519_company
  IdentitiesOnly yes
  AddKeysToAgent yes
  UseKeychain yes  # macOS
  # 安全加固
  StrictHostKeyChecking accept-new
  ServerAliveInterval 60
  ServerAliveCountMax 3
  # 限制命令（可选，需服务端配合）
  # Command="git-receive-pack '--strict' '$SSH_ORIGINAL_COMMAND'"

# --- 个人实验仓库 (低权限) ---
Host github-personal
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519_personal
  IdentitiesOnly yes
  AddKeysToAgent yes
  # 允许转发（仅个人环境）
  ForwardAgent yes

# --- 客户交付仓库 (隔离 + 审计) ---
Host github-client-*
  HostName github.com
  User git
  # 动态匹配客户密钥：~/.ssh/id_ed25519_client_<name>
  IdentityFile ~/.ssh/id_ed25519_client_%h
  IdentitiesOnly yes
  # 严格隔离：禁止代理转发 + 禁止端口转发
  ForwardAgent no
  PermitLocalCommand no
  ClearAllForwardings yes
  # 审计日志（记录所有操作）
  # LogLevel VERBOSE

# --- 生产部署服务器 (最高安全等级) ---
Host quant-prod-*
  # 动态匹配：quant-prod-bj, quant-prod-sh
  HostName %h.quant-company.com
  User quant-deploy
  IdentityFile ~/.ssh/id_ed25519_deploy
  IdentitiesOnly yes
  # 强制命令限制（服务端 authorized_keys 中配置）
  # command="rsync --server..."
  # 安全加固
  StrictHostKeyChecking yes
  PasswordAuthentication no
  ChallengeResponseAuthentication no
  KbdInteractiveAuthentication no
  # 会话超时
  ServerAliveInterval 30
  ServerAliveCountMax 2

# --- 默认回退 (防误用) ---
Host *
  # 默认使用个人密钥（最低权限）
  IdentityFile ~/.ssh/id_ed25519_personal
  AddKeysToAgent yes
  # 禁用危险选项
  ForwardAgent no
  PermitLocalCommand no
