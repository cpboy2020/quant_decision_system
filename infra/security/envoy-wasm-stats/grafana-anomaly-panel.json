{
  "__inputs": [{"name":"DS_PROMETHEUS","label":"Prometheus","type":"datasource","pluginId":"prometheus"}],
  "panels":[
    {"datasource":{"type":"prometheus","uid":"${DS_PROMETHEUS}"},"gridPos":{"h":7,"w":12,"x":0,"y":0},"id":1,"title":"📈 WASM 审计吞吐 (RPS) & 异常检测 (Z-Score)","type":"timeseries",
     "targets":[
       {"expr":"rate(audit_requests_total[5m])","legendFormat":"Audit RPS","refId":"A"},
       {"expr":"(rate(audit_requests_total[5m]) - avg_over_time(rate(audit_requests_total[5m])[1h:5m])) / stddev_over_time(rate(audit_requests_total[5m])[1h:5m])","legendFormat":"Z-Score","refId":"B"}
     ],
     "fieldConfig":{"overrides":[{"matcher":{"id":"byName","options":"Z-Score"},"properties":[{"id":"thresholds","value":{"steps":[{"color":"green","value":null},{"color":"yellow","value":2},{"color":"red","value":3}]}},{"id":"custom.lineStyle","value":{"fill":"dash"}}]}]}
    },
    {"datasource":{"type":"prometheus","uid":"${DS_PROMETHEUS}"},"gridPos":{"h":7,"w":6,"x":12,"y":0},"id":2,"title":"⏱️ P50/P95/P99 延迟分布 (μs)","type":"timeseries",
     "targets":[
       {"expr":"histogram_quantile(0.50, rate(audit_latency_us_bucket[5m]))","legendFormat":"P50"},
       {"expr":"histogram_quantile(0.95, rate(audit_latency_us_bucket[5m]))","legendFormat":"P95"},
       {"expr":"histogram_quantile(0.99, rate(audit_latency_us_bucket[5m]))","legendFormat":"P99"}
     ]},
    {"datasource":{"type":"prometheus","uid":"${DS_PROMETHEUS}"},"gridPos":{"h":7,"w":6,"x":18,"y":0},"id":3,"title":"🔥 审计错误率 & 链上提交失败","type":"stat",
     "targets":[{"expr":"rate(audit_errors_total[5m])/(rate(audit_requests_total[5m])+0.001)*100","legendFormat":"Error %"}],
     "fieldConfig":{"defaults":{"unit":"percent","thresholds":{"steps":[{"color":"green","value":null},{"color":"red","value":1}]}}}}
  ],
  "schemaVersion":39,"title":"🛡️ Envoy WASM 审计性能与异常面板","version":1
}
